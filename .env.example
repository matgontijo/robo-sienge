# Sienge
SIENGE_BASE_URL=https://api.sienge.com.br/{subdomain}/public/api/v1
SIENGE_USERNAME=seu_usuario
SIENGE_PASSWORD=sua_senha

# Santander API DDA
SANTANDER_CLIENT_ID=
SANTANDER_CLIENT_SECRET=
SANTANDER_CERT_PATH=./certs/santander.pfx
SANTANDER_CERT_PASSWORD=
SANTANDER_ENV=production  # ou sandbox

# Anthropic (Claude Haiku — OCR)
ANTHROPIC_API_KEY=

# SEFAZ
SEFAZ_CERT_PATH=./certs/empresa_a1.pfx
SEFAZ_CERT_PASSWORD=
SEFAZ_CNPJ=00000000000000
SEFAZ_AMBIENTE=1  # 1=produção, 2=homologação
SEFAZ_NSU_ULTIMO=0  # atualizado automaticamente a cada execução

# Notificações
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIF_EMAIL_DESTINO=financeiro@empresa.com.br
# Opcional: Teams webhook
TEAMS_WEBHOOK_URL=

# Scheduler
CRON_HORA=07
CRON_MINUTO=00

# Saída
OUTPUT_DIR=./output
LOGS_DIR=./logs

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=troque_esta_senha
DASHBOARD_DB_PATH=./dashboard.db
